# =============================================================================
# SerenBot — Variáveis de Ambiente
# Copiar para .env e preencher todos os campos marcados com <REQUIRED>
# =============================================================================

# ─── Identidade da Aplicação ──────────────────────────────────────────────────
APP_NAME=Bliss Touch by Paulo          # Nome da aplicação (usado no OpenRouter e User-Agent)
SITE_URL=https://tratamentes.pt        # URL pública do site
BOT_CLIENT_NAME=Noa                    # Nome do agente cliente (ex: Noa, Sara, Bot)

# ─── Localização do Prestador (para cálculo de distância ao domicílio) ────────
PROVIDER_ADDRESS=Rua Jorge Colaço, 32A, 1700-253 Lisboa
PROVIDER_LAT=38.7677
PROVIDER_LON=-9.1387

# ─── Cal.com / Cal.eu ─────────────────────────────────────────────────────────
CALCOM_BASE_URL=https://api.cal.com/v2 # cal.com (default) ou https://api.cal.eu/v2 para cal.eu
CALCOM_API_KEY=<REQUIRED>              # Bearer token da API
CALCOM_USERNAME=<REQUIRED>             # Username do calendário (ex: paulo-massagem-e-terapias-manuais)
CALCOM_TIMEZONE=Europe/Lisbon

# ─── Kommo CRM ───────────────────────────────────────────────────────────────
KOMMO_SUBDOMAIN=<REQUIRED>             # Ex: minhaempresa (sem .kommo.com)
KOMMO_ACCESS_TOKEN=<REQUIRED>          # Long-lived token do OAuth
KOMMO_RESPONSIBLE_USER_ID=<REQUIRED>   # ID do utilizador responsável pelas leads

# Pipeline e status IDs — obter em: Kommo → Configurações → Funis → inspecionar via API
KOMMO_PIPELINE_ID=<REQUIRED>           # Funil de Vendas (novos clientes)
KOMMO_PIPELINE_ATIVOS_ID=<REQUIRED>    # Funil de Clientes Activos (recorrentes)
KOMMO_STATUS_AGENDADO=<REQUIRED>       # ID do status "AGENDADO" no funil principal
KOMMO_STATUS_ATIVOS_AGENDADO=<REQUIRED># ID do status "AGENDADO" no funil de activos

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_B_TOKEN=<REQUIRED>        # Token do bot admin (Bot B / Flux)
TELEGRAM_ADMIN_ID=<REQUIRED>           # Chat ID do administrador (para notificações)

# ─── OpenRouter ───────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=<REQUIRED>          # API key do OpenRouter

# ─── Segurança da API local ───────────────────────────────────────────────────
API_TOKEN=<REQUIRED>                   # Token para proteger endpoints da API local
WEBHOOK_SECRET=<REQUIRED>              # Segredo HMAC para verificar webhooks do Cal.eu

# ─── OpenClaw ────────────────────────────────────────────────────────────────
OPENCLAW_AGENT_NAME=cliente            # Nome do agente cliente no OpenClaw (pasta de sessões)
# OPENCLAW_SESSIONS_DIR=               # Opcional: path absoluto para sobrepor o default

# ─── Graphify (Knowledge Graph) ───────────────────────────────────────────────
# GRAPH_PATH=                          # Opcional: path absoluto para graphify-out/
#                                      # Default: $HOME/graphify-out
