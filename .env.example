# SerenBot — Variáveis de Ambiente
# Copiar para /opt/serenbot/.env e preencher todos os campos marcados <REQUIRED>
# sudo chmod 600 /opt/serenbot/.env   (nunca commitar este ficheiro)

# ── Identidade ────────────────────────────────────────────────────────────────
APP_NAME=Tratamentes
BOT_CLIENT_NAME=Seren
API_PORT=3002

# ── Telegram ──────────────────────────────────────────────────────────────────
# Bot Seren Lite — recebe mensagens de clientes via webhook nativo
TELEGRAM_TOKEN_AGENT1=<REQUIRED>        # token do suporte_tratamentes_bot (BotFather)

# Bot de notificações ao admin (notify.js — modo só-envio)
TELEGRAM_BOT_B_TOKEN=<REQUIRED>         # token separado para alertas ao João

# Chat ID do administrador
TELEGRAM_ADMIN_ID=<REQUIRED>            # obter enviando msg a @userinfobot

# Secret para validar POST /telegram/seren (configurar também no setWebhook)
TELEGRAM_WEBHOOK_SECRET=<REQUIRED>      # openssl rand -hex 32

# ── Cal.com ───────────────────────────────────────────────────────────────────
CALCOM_BASE_URL=https://api.cal.com/v2
CALCOM_API_KEY=<REQUIRED>               # cal.com → Settings → API Keys
CALCOM_USERNAME=<REQUIRED>              # slug do calendário (aparece no URL das reservas)
CALCOM_TIMEZONE=Europe/Lisbon

# ── Kommo CRM ─────────────────────────────────────────────────────────────────
KOMMO_SUBDOMAIN=<REQUIRED>              # ex: minhaempresa (sem .kommo.com)
# Token JWT long-lived — Kommo → Configurações → Integrações → API
# ATENÇÃO: verificar data de expiração e renovar antes de expirar
KOMMO_ACCESS_TOKEN=<REQUIRED>
KOMMO_RESPONSIBLE_USER_ID=<REQUIRED>    # ID do utilizador responsável pelas leads

# IDs dos pipelines:
# curl "https://{subdomain}.kommo.com/api/v4/leads/pipelines" \
#      -H "Authorization: Bearer $KOMMO_ACCESS_TOKEN" | python3 -m json.tool
KOMMO_PIPELINE_ID=<REQUIRED>            # Funil de Vendas (novos clientes)
KOMMO_PIPELINE_ATIVOS_ID=<REQUIRED>     # Clientes Ativos (recorrentes)

# IDs dos stages "Agendado" em cada pipeline (obter do endpoint acima)
KOMMO_STATUS_AGENDADO=<REQUIRED>
KOMMO_STATUS_ATIVOS_AGENDADO=<REQUIRED>

# ── Segurança API ─────────────────────────────────────────────────────────────
# Protege endpoints /admin/* e chamadas externas à API
API_TOKEN=<REQUIRED>                    # openssl rand -hex 32

# HMAC SHA-256 para validar webhooks Cal.com — configurar também no painel Cal.com
# Nota: Cal.com envia hex puro, sem prefixo sha256=
WEBHOOK_SECRET=<REQUIRED>               # openssl rand -hex 32

# ── OpenRouter (LLM fallback Seren Lite) ─────────────────────────────────────
# Usado em llm-fallback.js para intenções desconhecidas (modelo: google/gemini-flash)
OPENROUTER_API_KEY=<REQUIRED>           # openrouter.ai → Keys

